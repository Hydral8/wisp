ANTHROPIC_API_KEY=
BROWSER_USE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# MCP server API keys (as needed)
MINIMAX_API_KEY=
ELEVENLABS_API_KEY=
ALLVOICELAB_API_KEY=
SCRAPELESS_KEY=
PEARCH_API_KEY=
IP2LOCATION_API_KEY=
CONTEXT7_API_KEY=
FREEPIK_API_KEY=
TWO_SLIDES_API_KEY=
COINGECKO_DEMO_API_KEY=
DEDALUS_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
RESEND_API_KEY=
LIBRARIES_IO_API_KEY=

# Service config
MINIMAX_API_HOST=https://api.minimax.io
MINIMAX_GROUP_ID=
COINGECKO_ENVIRONMENT=demo
